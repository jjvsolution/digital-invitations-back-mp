datasource db {
  provider = "postgresql"
  schemas = ["digital-invitations"]
}

generator client {
  provider = "prisma-client-js"
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum EventType {
  BAUTIZO
  CUMPLEANOS
  MATRIMONIO
  BABY_SHOWER
  FIESTA
  @@schema("digital-invitations")
}

enum InvitationStatus {
  DRAFT
  PUBLISHED
  @@schema("digital-invitations")
}

enum RsvpStatus {
  CONFIRMED
  DECLINED
  MAYBE
  @@schema("digital-invitations")
}

enum GuestSendMethod {
  WA_ME
  CLOUD_API
  /** Marcado manual en el panel (envío por WhatsApp fuera del sistema o ya hecho) */
  MANUAL
  @@schema("digital-invitations")
}

//////////////////////////////////////
// USER (opcional para MVP, recomendado)
//////////////////////////////////////

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  invitations  Invitation[]
  createdAt    DateTime      @default(now())
  @@schema("digital-invitations")
}

//////////////////////////////////////
// TEMPLATE
//////////////////////////////////////

model Template {
  id               String   @id @default(uuid())
  name             String   @unique
  eventType        EventType
  previewImageUrl  String?
  defaultSettings  Json     // colores, fonts, estilos
  defaultSections  Json     // qué secciones vienen activas
  createdAt        DateTime @default(now())

  invitations      Invitation[]
  @@schema("digital-invitations")
}

//////////////////////////////////////
// INVITATION
//////////////////////////////////////

model Invitation {
  id            String             @id @default(uuid())
  slug          String             @unique
  title         String
  eventType     EventType
  status        InvitationStatus   @default(DRAFT)

  eventDate     DateTime
  locationName String?
  address       String?
  latitude      Float?
  longitude     Float?

  coverImageUrl String?
  message       String?

  settings      Json               // override de template (colores, fuentes, portada, orden secciones)
  sections      Json               // activación/config de secciones

  userId        String?
  templateId    String

  user          User?              @relation(fields: [userId], references: [id])
  template      Template           @relation(fields: [templateId], references: [id])

  photos        Photo[]
  rsvps         Rsvp[]
  musicSuggestions MusicSuggestion[]
  giftSuggestions  GiftSuggestion[]
  invitationGuests InvitationGuest[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  @@schema("digital-invitations")
}

//////////////////////////////////////
// PHOTOS (GALERÍA)
//////////////////////////////////////

model Photo {
  id           String   @id @default(uuid())
  invitationId String
  imageUrl     String
  caption      String?
  order        Int      @default(0)

  invitation   Invitation @relation(fields: [invitationId], references: [id])

  createdAt    DateTime @default(now())

  @@index([invitationId])
  @@schema("digital-invitations")
}


//////////////////////////////////////
// RSVP
//////////////////////////////////////

model Rsvp {
  id            String     @id @default(uuid())
  invitationId  String
  name          String
  email         String?
  phone         String?
  guestsCount  Int        @default(1)
  status        RsvpStatus
  message       String?

  invitation    Invitation @relation(fields: [invitationId], references: [id])

  createdAt     DateTime @default(now())
  @@schema("digital-invitations")
}

//////////////////////////////////////
// MUSIC SUGGESTIONS
//////////////////////////////////////

model MusicSuggestion {
  id            String   @id @default(uuid())
  invitationId  String
  name          String
  artist        String?
  link          String?

  invitation    Invitation @relation(fields: [invitationId], references: [id])

  createdAt     DateTime @default(now())
  @@schema("digital-invitations")
}

//////////////////////////////////////
// GIFT SUGGESTIONS
//////////////////////////////////////

model GiftSuggestion {
  id            String   @id @default(uuid())
  invitationId  String
  name          String
  link          String?
  message       String?

  invitation    Invitation @relation(fields: [invitationId], references: [id])

  createdAt     DateTime @default(now())
  @@schema("digital-invitations")
}

//////////////////////////////////////
// INVITATION GUESTS (difusión / Excel)
//////////////////////////////////////

model InvitationGuest {
  id               String   @id @default(uuid())
  invitationId     String
  firstName        String
  lastName         String
  /** E.164, ej. +5491123456789 */
  phone            String
  messageOverride  String?

  lastSentAt       DateTime?
  lastSendMethod   GuestSendMethod?
  lastError        String?

  invitation       Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([invitationId])
  @@schema("digital-invitations")
}
